{
  "version": "2.0.0",
  "tasks": [
    
      {
        "label": "prebuild app",
        "command": "g++ -Wall -Wextra -g -std=c++23 -Og -c '../sources/*.cpp' -I '../headers' -I '../../.dependencies/headers'  -I '../../Pandora Core/headers' -I '../../Pandora IO/headers'",
        "type": "shell",
        "problemMatcher": [
          "$msCompile",
          "$gcc"
        ],
        "options": {
          "cwd": "${workspaceFolder}/app/.temp"
        },
        "presentation": {
          "reveal": "always",
          "clear": false,
          "showReuseMessage": false,
          "close": false,
          "focus": true
        },
        "group": "build"
      },
      {
        "label": "app",
        "command": "robocopy \"app\\resources\" \".bin\\app\\resources\" /mir & powershell -Command \"g++ -Wall -Wextra -g -std=c++23 -Og 'app/.temp/*.o' -o '.bin/app/app.exe' '.bin/Pandora Core.dll' '.bin/Pandora IO.dll'\" & del \"app\\.temp\\*.o\"",
        "type": "shell",
        "problemMatcher": [
          "$msCompile",
          "$gcc"
        ],
        "presentation": {
          "reveal": "always",
          "clear": false,
          "showReuseMessage": false,
          "close": false,
          "focus": true
        },
        "group": "build",
        "dependsOn": [ "prebuild app" ],
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": [
              "/d",
              "/c"
            ]
          },
          "cwd": "${workspaceFolder}"
        }
      },
    
{
  "label": "Pandora IO",
  "command": "powershell -Command \"g++ -Wall -Wextra -g -std=c++23 -Og -c -shared '../sources/*.cpp' -I '../headers' -I '../../.dependencies/headers'\" & cd ../../ & powershell -Command \"g++ -Wall -Wextra -g -std=c++23 -Og 'Pandora IO/.temp/*.o' -shared -o '.bin/Pandora IO.dll'\" & cd \"Pandora IO/.temp\" & del *.o",
  "type": "shell",
  "problemMatcher": [
    "$msCompile",
    "$gcc"
  ],
  "presentation": {
    "reveal": "always",
    "clear": false,
    "showReuseMessage": false,
    "close": false,
    "focus": true
  },

  "group": "build",
  "options": {
    "shell": {
      "executable": "cmd.exe",
      "args": [
        "/d",
        "/c"
      ]
    },
    "cwd": "${workspaceFolder}/Pandora IO/.temp"
  }
},
    {
      "label": "vsc Build all",
      "dependsOn": [ "vsc Build dlls", "vsc Build apps" ],
      "dependsOrder": "sequence"
    },
    {
      "label": "vsc Build dlls",
      "dependsOn": [ "Pandora IO", ],
      "dependsOrder": "parallel"
    },
    {
      "label": "vsc Build apps",
      "dependsOn": [ "app", ],
      "dependsOrder": "parallel"
    },
    {
      "label": "vsc INIT Build",
      "dependsOn": "vsc Build all",
      "type": "shell",
      "command":"xcopy .dependencies\\dll\\*.dll .bin /y & cd .bin & FOR /d %D in (*) do call xcopy *.dll \"%~fD\" /D /K /Y > nul & cd ../.vscode & del *.build",
      "presentation": {
        "reveal": "always",
        "clear": false,
        "showReuseMessage": false,
        "close": false,
        "focus": true
      },
      "group": "build",
      "options": {
        "shell": {
          "executable": "cmd.exe",
          "args": [
            "/d",
            "/c"
          ]
        },
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}